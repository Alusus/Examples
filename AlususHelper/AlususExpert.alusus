@merge module AlususHelper {
    def OVECCOUNT: int = 30;
    // Must be a multiple of 3
    func cleanAndExtractCode(llmOutput: String): String {
        def cleanedText: String = removeThinkSection(llmOutput);
        if (cleanedText == String("")) {
            return(String("Cannot answer this question"));
        }
        cleanedText = cleanedText.trim();
        def regStr: String;
        regStr = "<code>(.*?)</code>";
        def regExp: RegExp;
        regExp.initialize(regStr.buf);
        def result: Array[String];
        result = regExp.match(cleanedText.buf);
        if result.getLength() > 1 return result(1);
        return String("PCRE compilation failed");
    }

    func generatePrompt(code: String, docs: Json): String {
        def separator: String = "\n******\n";
        def numDocs: int = docs.getLength();
        def inlineDocsLen: int = 0;
        def i: int = 0;
        def doc: String;
        for i = 0, i < numDocs;
        i++{
            doc = docs(i);
            inlineDocsLen += doc.getLength();
            if i < numDocs - 1 {
                inlineDocsLen += separator.getLength();
            }
        }
        def inlineDocs: String;
        inlineDocs.alloc(inlineDocsLen);
        inlineDocs = "";
        for i = 0, i < numDocs, i++ {
            doc = docs(i);
            inlineDocs += doc
                if i < numDocs - 1 {
                inlineDocs += separator;
            }
        }
        def promptSize: int = inlineDocs.getLength() + code.getLength() + 512;
        def prompt: String;
        prompt.alloc(promptSize);
        // Format the prompt
        prompt = String.format("You are an expert in Alusus programming language.\n"
            "You should be able to use the docs to help you check the code for syntax error and correct them.\n"
            "If something is not mentioned in the docs leave it as it is, do not make assumptions on your own!\n"
            "Documents:\n%s\n"
            "Code:\n"
            "```%s```\n"
            "Do not modify the approach or the code logic even if it's wrong! just correct any syntax errors.\n"
            "Please think about what you should correct between <think></think> tags.\n"
            "Please put the full code after correction between <code></code> tags.\n"
            "The code will be treated as a final answer so make sure it's complete!\n"
            "Some syntax errors may be repeated across the code, make sure that everything is corrected!\n"
            "If a feature is described in docs, any other way of using that feature must be wrong!\n",
            inline_docs.buf, code.buf);

        return prompt;
    }

    func promptAlususExpert(code: String, syntaxDocs: Json, apiKey: String): String {
        def prompt: String = generatePrompt(code, syntaxDocs);
        def response: String = sendRequest(apiKey, prompt, "o3-mini");
        def cleanResponse: String = cleanAndExtractCode(response);
        return cleanResponse;
    }
}